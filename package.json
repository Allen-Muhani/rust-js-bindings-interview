{
  "name": "rust-js-bindings",
  "version": "0.1.0",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --platform --release --js _binding.js --dts _binding.d.ts && tsc",
    "build:debug": "napi build --platform --js _binding.js --dts _binding.d.ts && tsc",
    "test": "node test.js",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/express-serve-static-core": "^5.1.1",
    "typescript": "^6.0.3"
  },
  "napi": {
    "binaryName": "rust-js-bindings",
    "targets": [
      "x86_64-unknown-linux-gnu"
    ]
  },
  "license": "MIT"
}
